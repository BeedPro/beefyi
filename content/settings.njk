---js
const eleventyNavigation = {
	key: "Settings",
	order: 5
};
---
<h1>Settings</h1>

<p class="theme-label">Theme mode</p>
<label class="theme-system-toggle" for="theme-system-toggle">
	<input id="theme-system-toggle" type="checkbox" name="theme-system-toggle">
	<span>Use system theme</span>
</label>

<fieldset class="theme-options" aria-label="Theme mode">
	<label class="theme-option" for="theme-dark">
		<input id="theme-dark" type="radio" name="theme-select" value="dark">
		<span class="theme-preview theme-preview-dark" aria-hidden="true">
			<span></span><span></span><span></span>
		</span>
		<span class="theme-option-title">Dark</span>
		<span class="theme-option-desc">Always use Modus Vivendi</span>
	</label>
	<label class="theme-option" for="theme-light">
		<input id="theme-light" type="radio" name="theme-select" value="light">
		<span class="theme-preview theme-preview-light" aria-hidden="true">
			<span></span><span></span><span></span>
		</span>
		<span class="theme-option-title">Light</span>
		<span class="theme-option-desc">Always use Modus Operandi</span>
	</label>
</fieldset>

<label class="theme-label" for="font-size-range">Font size</label>
<section class="font-size-settings" aria-label="Font size settings">
	<select id="font-size-range" class="font-size-select" name="font-size-range" aria-label="Site font size">
		<option value="75">75%</option>
		<option value="100">100%</option>
		<option value="125">125%</option>
		<option value="150">150%</option>
		<option value="175">175%</option>
		<option value="200">200%</option>
	</select>
</section>

<label class="theme-label" for="reading-range">Reading Width</label>
<section class="reading-settings" aria-label="Reading width settings">
	<input id="reading-range" class="reading-range" type="range" min="0" max="100" step="1" value="50" aria-label="Reading width level">
	<div class="reading-scale" aria-hidden="true">
		<span>Compact</span>
		<span>Balanced</span>
		<span>Comfort</span>
	</div>
</section>
