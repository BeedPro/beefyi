---js
const eleventyNavigation = {
	key: "Settings",
	order: 5
};
---
<h1>Settings</h1>

<p class="theme-label">Theme mode</p>
<label class="theme-system-toggle" for="theme-system-toggle">
	<input id="theme-system-toggle" type="checkbox" name="theme-system-toggle">
	<span>Use system theme</span>
</label>

<fieldset class="theme-options" aria-label="Theme mode">
	<label class="theme-option" for="theme-dark">
		<input id="theme-dark" type="radio" name="theme-select" value="dark">
		<span class="theme-preview theme-preview-dark" aria-hidden="true">
			<span></span><span></span><span></span>
		</span>
		<span class="theme-option-title">Dark</span>
		<span class="theme-option-desc">Always use Zen</span>
	</label>
	<label class="theme-option" for="theme-light">
		<input id="theme-light" type="radio" name="theme-select" value="light">
		<span class="theme-preview theme-preview-light" aria-hidden="true">
			<span></span><span></span><span></span>
		</span>
		<span class="theme-option-title">Light</span>
		<span class="theme-option-desc">Always use Pearl</span>
	</label>
</fieldset>

<p class="theme-label">Reading mode</p>
<section class="reading-settings" aria-label="Reading mode settings">
	<div class="reading-preset-grid" role="group" aria-label="Reading presets">
		<button class="reading-preset" type="button" data-reading-preset="0">Compact</button>
		<button class="reading-preset" type="button" data-reading-preset="50">Balanced</button>
		<button class="reading-preset" type="button" data-reading-preset="100">Comfort</button>
	</div>
	<input id="reading-range" class="reading-range" type="range" min="0" max="100" step="1" value="50" aria-label="Reading level">
	<div class="reading-scale" aria-hidden="true">
		<span>Compact</span>
		<span>Balanced</span>
		<span>Comfort</span>
	</div>
	<p class="reading-value" id="reading-value">Reading: Balanced (50)</p>
</section>
