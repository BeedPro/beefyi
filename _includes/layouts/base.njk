<!doctype html>
<html lang="{{ metadata.language }}">
	<head>
		<meta charset="utf-8">
		<meta name="viewport" content="width=device-width, initial-scale=1.0">
		<title>{{ title or metadata.title }}</title>
		<meta name="description" content="{{ description or metadata.description }}">
		<link rel="alternate" href="/feed/feed.xml" type="application/atom+xml" title="{{ metadata.title }}">
		<link rel="icon" href="/favicon/favicon.ico" sizes="any">

		{#- Uncomment this if you’d like folks to know that you used Eleventy to build your site!  #}
		{#- <meta name="generator" content="{{ eleventy.generator }}"> #}

		{#-
		Plain-text bundles are provided via the `eleventy-plugin-bundle` plugin:
		1. CSS:
			* Add to a per-page bundle using `{% css %}{% endcss %}`
			* Retrieve bundle content using `{% getBundle "css" %}` or `{% getBundleFileUrl "css" %}`
		2. Or for JavaScript:
			* Add to a per-page bundle using `{% js %}{% endjs %}`
			* Retrieve via `{% getBundle "js" %}` or `{% getBundleFileUrl "js" %}`
		3. Learn more: https://github.com/11ty/eleventy-plugin-bundle
		#}

		{#- Add CSS to the bundle #}
		<style>/* This is an arbitrary CSS string added to the bundle */</style>
		<script eleventy:ignore>
			(function () {
				var themeStorageKey = "theme-preference";
				var fontSizeStorageKey = "font-size";
				var readingValueStorageKey = "reading-value";
				var legacyReadingStorageKey = "reading-preference";

				function clamp(value, min, max) {
					return Math.min(max, Math.max(min, value));
				}

				function lerp(start, end, amount) {
					return start + (end - start) * amount;
				}

				function readingVars(value) {
					var clamped = clamp(value, 0, 100);
					var compact = { fontSize: 0.95, lineHeight: 1.4, maxWidth: 36 };
					var balanced = { fontSize: 1, lineHeight: 1.5, maxWidth: 40 };
					var comfort = { fontSize: 1.06, lineHeight: 1.68, maxWidth: 46 };
					if (clamped <= 50) {
						var tA = clamped / 50;
						return {
							fontSize: lerp(compact.fontSize, balanced.fontSize, tA),
							lineHeight: lerp(compact.lineHeight, balanced.lineHeight, tA),
							maxWidth: lerp(compact.maxWidth, balanced.maxWidth, tA)
						};
					}
					var tB = (clamped - 50) / 50;
					return {
						fontSize: lerp(balanced.fontSize, comfort.fontSize, tB),
						lineHeight: lerp(balanced.lineHeight, comfort.lineHeight, tB),
						maxWidth: lerp(balanced.maxWidth, comfort.maxWidth, tB)
					};
				}

				function applyReading(value) {
					var vars = readingVars(value);
					document.documentElement.style.setProperty("--reading-font-scale", vars.fontSize.toFixed(3).replace(/\.0+$/, ""));
					document.documentElement.style.setProperty("--reading-line-height", vars.lineHeight.toFixed(3).replace(/\.0+$/, ""));
					document.documentElement.style.setProperty("--reading-max-width", vars.maxWidth.toFixed(3).replace(/\.0+$/, "") + "em");
					document.documentElement.setAttribute("data-reading-value", String(Math.round(value)));
				}

				function applyFontSize(value) {
					var rounded = Math.round(clamp(value, 75, 200));
					document.documentElement.style.setProperty("--site-font-size", rounded / 100 + "rem");
					document.documentElement.setAttribute("data-font-size", String(rounded));
				}

				var preference = "system";
				var fontSize = 100;
				var readingValue = 50;
				try {
					var stored = localStorage.getItem(themeStorageKey);
					if (stored === "light" || stored === "dark" || stored === "system") {
						preference = stored;
					}
					var storedFontSize = localStorage.getItem(fontSizeStorageKey);
					if (storedFontSize !== null && !Number.isNaN(Number(storedFontSize))) {
						fontSize = clamp(Number(storedFontSize), 75, 200);
					}
					var storedReadingValue = localStorage.getItem(readingValueStorageKey);
					if (storedReadingValue !== null && !Number.isNaN(Number(storedReadingValue))) {
						readingValue = clamp(Number(storedReadingValue), 0, 100);
					} else {
						var legacyReading = localStorage.getItem(legacyReadingStorageKey);
						if (legacyReading === "compact") {
							readingValue = 0;
						} else if (legacyReading === "comfortable") {
							readingValue = 100;
						}
					}
				} catch (e) {}
				var isDark = window.matchMedia && window.matchMedia("(prefers-color-scheme: dark)").matches;
				var resolved = preference === "system" ? (isDark ? "dark" : "light") : preference;
				document.documentElement.setAttribute("data-theme", resolved);
				document.documentElement.setAttribute("data-theme-preference", preference);
				applyFontSize(fontSize);
				applyReading(readingValue);
			})();
		</script>

		{#- Add the contents of a file to the bundle #}
		<style>{% include "css/index.css" %}</style>

		{#- Or you can add from node_modules #}
		{# <style>{% include "node_modules/something.css" %}</style> #}

		{#- Render the CSS bundle using inlined CSS (for the fastest site performance in production) #}
		<style>{% getBundle "css" %}</style>

		{#- Renders the CSS bundle using a separate file, if you can't set CSP directive style-src: 'unsafe-inline' #}
		{#- <link rel="stylesheet" href="{% getBundleFileUrl "css" %}"> #}

		{#- Add the heading-anchors web component to the JavaScript bundle #}
		<script type="module">{% include "node_modules/@zachleat/heading-anchors/heading-anchors.js" %}</script>
	</head>
	<body>
		<a href="#main" id="skip-link" class="visually-hidden">Skip to main content</a>

		<header>
			<a href="/" class="home-link">{{ metadata.title }}</a>

			{#- Read more about `eleventy-navigation` at https://www.11ty.dev/docs/plugins/navigation/ #}
			<nav>
				<h2 class="visually-hidden">Top level navigation menu</h2>
				<ul class="nav">
				{%- for entry in collections.all | eleventyNavigation %}
					<li class="nav-item"><a href="{{ entry.url }}"{% if entry.url == page.url %} aria-current="page"{% endif %}>{{ entry.title }}</a></li>
				{%- endfor %}
				</ul>
			</nav>
		</header>

		<main id="main">
			<heading-anchors>
				{{ content | safe }}
			</heading-anchors>
		</main>

		<!-- This page `{{ page.url }}` was built on {% currentBuildDate %} -->
		<script eleventy:ignore>
			(function () {
				var themeStorageKey = "theme-preference";
				var fontSizeStorageKey = "font-size";
				var readingValueStorageKey = "reading-value";
				var legacyReadingStorageKey = "reading-preference";
				var inputs = Array.prototype.slice.call(document.querySelectorAll('input[name="theme-select"]'));
				var systemToggle = document.getElementById("theme-system-toggle");
				var fontSizeRange = document.getElementById("font-size-range");
				var readingRange = document.getElementById("reading-range");
				if (inputs.length === 0 && !systemToggle && !fontSizeRange && !readingRange) {
					return;
				}

				function clamp(value, min, max) {
					return Math.min(max, Math.max(min, value));
				}

				function lerp(start, end, amount) {
					return start + (end - start) * amount;
				}

				function readingVars(value) {
					var clamped = clamp(value, 0, 100);
					var compact = { fontSize: 0.95, lineHeight: 1.4, maxWidth: 36 };
					var balanced = { fontSize: 1, lineHeight: 1.5, maxWidth: 40 };
					var comfort = { fontSize: 1.06, lineHeight: 1.68, maxWidth: 46 };
					if (clamped <= 50) {
						var tA = clamped / 50;
						return {
							fontSize: lerp(compact.fontSize, balanced.fontSize, tA),
							lineHeight: lerp(compact.lineHeight, balanced.lineHeight, tA),
							maxWidth: lerp(compact.maxWidth, balanced.maxWidth, tA)
						};
					}
					var tB = (clamped - 50) / 50;
					return {
						fontSize: lerp(balanced.fontSize, comfort.fontSize, tB),
						lineHeight: lerp(balanced.lineHeight, comfort.lineHeight, tB),
						maxWidth: lerp(balanced.maxWidth, comfort.maxWidth, tB)
					};
				}

				function applyReading(value) {
					var rounded = Math.round(clamp(value, 0, 100));
					var vars = readingVars(rounded);
					document.documentElement.style.setProperty("--reading-font-scale", vars.fontSize.toFixed(3).replace(/\.0+$/, ""));
					document.documentElement.style.setProperty("--reading-line-height", vars.lineHeight.toFixed(3).replace(/\.0+$/, ""));
					document.documentElement.style.setProperty("--reading-max-width", vars.maxWidth.toFixed(3).replace(/\.0+$/, "") + "em");
					document.documentElement.setAttribute("data-reading-value", String(rounded));
					return rounded;
				}

				function applyFontSize(value) {
					var rounded = Math.round(clamp(value, 75, 200));
					document.documentElement.style.setProperty("--site-font-size", rounded / 100 + "rem");
					document.documentElement.setAttribute("data-font-size", String(rounded));
					return rounded;
				}

				function readingLabel(value) {
					if (value === 0) {
						return "Compact";
					}
					if (value === 50) {
						return "Balanced";
					}
					if (value === 100) {
						return "Comfort";
					}
					return "Custom";
				}

				function snapReadingValue(value) {
					var rounded = Math.round(clamp(value, 0, 100));
					var snapTargets = [0, 50, 100];
					var snapDistance = 8;
					for (var i = 0; i < snapTargets.length; i++) {
						if (Math.abs(rounded - snapTargets[i]) <= snapDistance) {
							return snapTargets[i];
						}
					}
					return rounded;
				}

				function getStoredPreference() {
					var value = document.documentElement.getAttribute("data-theme-preference") || "system";
					if (value === "light" || value === "dark" || value === "system") {
						return value;
					}
					return "system";
				}

				function resolvedTheme(preference) {
					if (preference === "light" || preference === "dark") {
						return preference;
					}
					return window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
				}

				function setPreference(preference, persist) {
					var resolved = resolvedTheme(preference);
					document.documentElement.setAttribute("data-theme", resolved);
					document.documentElement.setAttribute("data-theme-preference", preference);
					if (persist !== false) {
						try {
							localStorage.setItem(themeStorageKey, preference);
						} catch (e) {}
					}
					updateInputs(preference, resolved);
				}

				function getStoredReadingValue() {
					var dataValue = Number(document.documentElement.getAttribute("data-reading-value"));
					if (!Number.isNaN(dataValue)) {
						return clamp(dataValue, 0, 100);
					}
					try {
						var stored = localStorage.getItem(readingValueStorageKey);
						if (stored !== null && !Number.isNaN(Number(stored))) {
							return clamp(Number(stored), 0, 100);
						}
						var legacy = localStorage.getItem(legacyReadingStorageKey);
						if (legacy === "compact") {
							return 0;
						}
						if (legacy === "comfortable") {
							return 100;
						}
					} catch (e) {}
					return 50;
				}

				function getStoredFontSize() {
					var dataValue = Number(document.documentElement.getAttribute("data-font-size"));
					if (!Number.isNaN(dataValue)) {
						return clamp(dataValue, 75, 200);
					}
					try {
						var stored = localStorage.getItem(fontSizeStorageKey);
						if (stored !== null && !Number.isNaN(Number(stored))) {
							return clamp(Number(stored), 75, 200);
						}
					} catch (e) {}
					return 100;
				}

				function setFontSize(value, persist) {
					var applied = applyFontSize(value);
					if (persist !== false) {
						try {
							localStorage.setItem(fontSizeStorageKey, String(applied));
						} catch (e) {}
					}
					updateFontSizeUI(applied);
				}

				function setReading(value, persist) {
					var applied = applyReading(snapReadingValue(value));
					if (persist !== false) {
						try {
							localStorage.setItem(readingValueStorageKey, String(applied));
						} catch (e) {}
					}
					updateReadingUI(applied);
				}

				function updateInputs(preference, resolved) {
					inputs.forEach(function (input) {
						var selected = input.value === preference && preference !== "system";
						input.checked = selected;
						var option = input.closest(".theme-option");
						if (option) {
							option.classList.toggle("is-selected", selected);
							option.setAttribute("aria-label", "Theme " + input.value + " (active palette: " + resolved + ")");
						}
					});
					if (systemToggle) {
						systemToggle.checked = preference === "system";
						systemToggle.setAttribute("aria-label", "Use system theme");
					}
				}

				function updateReadingUI(value) {
					if (readingRange) {
						readingRange.value = String(value);
						readingRange.setAttribute("aria-valuetext", readingLabel(value) + " reading width, level " + value);
					}
				}

				function updateFontSizeUI(value) {
					if (fontSizeRange) {
						fontSizeRange.value = String(value);
						fontSizeRange.setAttribute("aria-valuetext", value + "%");
					}
				}

				inputs.forEach(function (input) {
					input.addEventListener("change", function () {
						if (input.checked) {
							setPreference(input.value, true);
						}
					});
				});

				if (systemToggle) {
					systemToggle.addEventListener("change", function () {
						if (systemToggle.checked) {
							setPreference("system", true);
						} else {
							var selectedInput = inputs.find(function (input) {
								return input.checked;
							});
							setPreference(selectedInput ? selectedInput.value : "dark", true);
						}
					});
				}

				if (fontSizeRange) {
					fontSizeRange.addEventListener("change", function () {
						setFontSize(Number(fontSizeRange.value), true);
					});
				}

				if (readingRange) {
					readingRange.addEventListener("input", function () {
						setReading(Number(readingRange.value), true);
					});
				}

				var initialPreference = getStoredPreference();
				setPreference(initialPreference, false);
				setFontSize(getStoredFontSize(), false);
				setReading(getStoredReadingValue(), false);

				var mediaQuery = window.matchMedia("(prefers-color-scheme: dark)");
				var handleSystemChange = function () {
					if (getStoredPreference() === "system") {
						setPreference("system", false);
					}
				};

				if (mediaQuery.addEventListener) {
					mediaQuery.addEventListener("change", handleSystemChange);
				} else if (mediaQuery.addListener) {
					mediaQuery.addListener(handleSystemChange);
				}
			})();
		</script>
		<script type="module" src="{% getBundleFileUrl "js" %}"></script>
	</body>
</html>
